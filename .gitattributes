# Normalize line endings to LF in the repo, convert to OS native on checkout
* text=auto eol=lf

# Force LF for these file types always
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.html text eol=lf
*.css text eol=lf
*.conf text eol=lf
Dockerfile text eol=lf

# Binary files — no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
